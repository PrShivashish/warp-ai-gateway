# ─────────────────────────────────────────────────────────────
# Warp Dashboard Frontend — Environment Variables
#
# Copy this file to `.env.local` for local development.
# For Vercel production deployment, add these in:
#   Vercel Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# The URL of your deployed Hugging Face Space (no trailing slash)
# Example: https://shivashish-warp-gateway.hf.space
VITE_PRIMARY_API_URL=https://YOUR-HF-SPACE-URL.hf.space

# Same HF Space URL — the api-gateway runs on the same host
# behind nginx (traffic is routed by path prefix)
VITE_GATEWAY_API_URL=https://YOUR-HF-SPACE-URL.hf.space

# Optional: URL to your deployed docs site
# VITE_DOCS_URL=https://your-docs-site.com
